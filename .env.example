# Copie para ".env" e preencha. NUNCA commitar o ".env" real.

# Postgres (Neon) — pode ser o mesmo banco do Sentinela ou um projeto novo
DATABASE_URL=postgresql://usuario:senha@host/banco?sslmode=require

# VirusTotal (conta gratuita em virustotal.com)
VIRUSTOTAL_API_KEY=

# URLhaus Auth-Key (conta gratuita em auth.abuse.ch)
URLHAUS_AUTH_KEY=

# Slack webhook para alertas do monitoramento automático
SLACK_WEBHOOK_URL=
